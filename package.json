{
  "name": "citas-gestion-zonasurtech",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:setup": "docker run -d --name citas_db_local -e POSTGRES_USER=dev_admin -e POSTGRES_PASSWORD=dev_password -e POSTGRES_DB=citas_db_local -p 5432:5432 postgres:16-alpine && npx prisma db push && npx prisma db seed",
    "dev:db:stop": "docker stop citas_db_local && docker rm citas_db_local",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.1",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "12.34.3",
    "lenis": "1.3.17",
    "lucide-react": "0.575.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "6.9.2",
    "stripe": "20.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.3",
    "@types/node": "20.17.16",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "eslint": "9.19.0",
    "eslint-config-next": "16.1.6",
    "postcss": "8.5.2",
    "prisma": "5.22.0",
    "tailwindcss": "4.1.3",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
